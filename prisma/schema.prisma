generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth) ───────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Usuários ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  bio           String?
  role          Role      @default(STUDENT)
  password      String?

  // Stripe
  stripeCustomerId   String?            @unique
  subscriptionId     String?            @unique
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  subscriptionPlan   SubscriptionPlan?
  subscriptionEndsAt DateTime?

  instructorStatus   InstructorStatus @default(NONE)
  instructorBio      String?
  instructorLinkedin String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts     Account[]
  sessions     Session[]
  courses      Course[]      @relation("InstructorCourses")
  enrollments  Enrollment[]
  reviews      Review[]
  progress     Progress[]
  quizAttempts QuizAttempt[]
  certificates Certificate[]
  news         News[]        @relation("NewsAuthor")

  posts           Post[]         @relation("PostAuthor")
  postComments    PostComment[]  @relation("CommentAuthor")
  postVotes       PostVote[]     @relation("PostVotes")
  commentVotes    CommentVote[]  @relation("CommentVotes")
  savedPosts      SavedPost[]    @relation("SavedPosts")
  connectionsFrom Connection[]   @relation("ConnectionsFrom")
  connectionsTo   Connection[]   @relation("ConnectionsTo")
  chatMembers     ChatMember[]
  chatMessages    ChatMessage[]  @relation("ChatMessageAuthor")
  xp              UserXP?
  badges          UserBadge[]
  notifications   Notification[]
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
}

enum SubscriptionPlan {
  MONTHLY
  ANNUAL
}

enum InstructorStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

// ─── Categorias ────────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  createdAt   DateTime @default(now())

  courses Course[]
}

// ─── Cursos ────────────────────────────────────────────────────────────────────

model Course {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String?
  thumbnail   String?
  price       Float   @default(0)
  isFree      Boolean @default(true)
  isPublished Boolean @default(false)
  level       Level   @default(BEGINNER)
  language    String  @default("pt-BR")
  duration    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instructorId String
  instructor   User      @relation("InstructorCourses", fields: [instructorId], references: [id])
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])

  modules      Module[]
  enrollments  Enrollment[]
  reviews      Review[]
  certificates Certificate[]
  tags         CourseTag[]
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

// ─── Tags ──────────────────────────────────────────────────────────────────────

model Tag {
  id      String      @id @default(cuid())
  name    String      @unique
  courses CourseTag[]
}

model CourseTag {
  courseId String
  tagId    String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([courseId, tagId])
}

// ─── Módulos e Aulas ───────────────────────────────────────────────────────────

model Module {
  id       String   @id @default(cuid())
  title    String
  order    Int
  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]

  createdAt DateTime @default(now())
}

model Lesson {
  id          String     @id @default(cuid())
  title       String
  description String?
  videoUrl    String?
  duration    Int?
  order       Int
  isFree      Boolean    @default(false)
  type        LessonType @default(VIDEO)
  content     String?
  moduleId    String
  module      Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress    Progress[]
  quiz        Quiz?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LessonType {
  VIDEO
  TEXT
  QUIZ
  NOTEBOOK
}

// ─── Quizzes ───────────────────────────────────────────────────────────────────

model Quiz {
  id                  String        @id @default(cuid())
  lessonId            String        @unique
  title               String
  description         String?
  passingScore        Int           @default(70)
  maxAttempts         Int?
  isCertificationExam Boolean       @default(false)
  lesson              Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions           Question[]
  attempts            QuizAttempt[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Question {
  id        String             @id @default(cuid())
  text      String
  order     Int                @default(1)
  quizId    String
  quiz      Quiz               @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options   Option[]
  responses QuestionResponse[]
}

model Option {
  id         String             @id @default(cuid())
  text       String
  order      Int                @default(1)
  isCorrect  Boolean            @default(false)
  questionId String
  question   Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  responses  QuestionResponse[]
}

model QuizAttempt {
  id            String             @id @default(cuid())
  quizId        String
  userId        String
  attemptNumber Int
  score         Int
  passed        Boolean            @default(false)
  submittedAt   DateTime           @default(now())
  quiz          Quiz               @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses     QuestionResponse[]

  @@unique([quizId, userId, attemptNumber])
}

model QuestionResponse {
  id         String      @id @default(cuid())
  attemptId  String
  questionId String
  optionId   String?
  attempt    QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question   Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option     Option?     @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@unique([attemptId, questionId])
}

// ─── Matrículas ────────────────────────────────────────────────────────────────

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId    String
  status      EnrollmentStatus @default(ACTIVE)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// ─── Progresso ─────────────────────────────────────────────────────────────────

model Progress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

// ─── Avaliações ────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

// ─── Certificados ──────────────────────────────────────────────────────────────

model Certificate {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  issuedAt   DateTime @default(now())
  code       String   @unique @default(cuid())
  finalScore Int?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

// ─── Banners ───────────────────────────────────────────────────────────────────

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  ctaText   String?
  ctaUrl    String   @default("/cursos")
  imageUrl  String?
  bgColor   String   @default("#edf5ff")
  textColor String   @default("#161616")
  isActive  Boolean  @default(true)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Notícias (News) ───────────────────────────────────────────────────────────

model News {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  summary   String?
  content   String   @db.Text
  imageUrl  String?
  category  String?
  published Boolean  @default(false)
  authorId  String
  author    User     @relation("NewsAuthor", fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InterestLead {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String?
  message   String?  @db.Text
  createdAt DateTime @default(now())
}

// ─── Comunidade ────────────────────────────────────────────────────────────────

model Post {
  id        String     @id @default(cuid())
  title     String
  body      String?    @db.Text
  type      PostType   @default(TEXT)
  tags      String[]
  views     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  authorId  String
  author    User       @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  comments  PostComment[]
  votes     PostVote[]
  savedBy   SavedPost[]
}

model SavedPost {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user      User     @relation("SavedPosts", fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

enum PostType {
  TEXT
  LINK
  CODE
  REPO
}

model PostComment {
  id        String   @id @default(cuid())
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId  String
  author    User     @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  parentId  String?
  parent    PostComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   PostComment[] @relation("CommentReplies")

  votes     CommentVote[]
}

model PostVote {
  id     String @id @default(cuid())
  value  Int
  userId String
  postId String

  user   User   @relation("PostVotes", fields: [userId], references: [id], onDelete: Cascade)
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model CommentVote {
  id        String      @id @default(cuid())
  value     Int
  userId    String
  commentId String

  user      User        @relation("CommentVotes", fields: [userId], references: [id], onDelete: Cascade)
  comment   PostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

// ─── Conexões ──────────────────────────────────────────────────────────────────

model Connection {
  id        String           @id @default(cuid())
  fromId    String
  toId      String
  status    ConnectionStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  from      User             @relation("ConnectionsFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to        User             @relation("ConnectionsTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── Chat ──────────────────────────────────────────────────────────────────────

model ChatRoom {
  id        String        @id @default(cuid())
  name      String?
  isGroup   Boolean       @default(false)
  createdAt DateTime      @default(now())

  members   ChatMember[]
  messages  ChatMessage[]
}

model ChatMember {
  roomId   String
  userId   String
  joinedAt DateTime  @default(now())

  room     ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  body      String   @db.Text
  roomId    String
  authorId  String
  createdAt DateTime @default(now())

  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author    User     @relation("ChatMessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)
}

// ─── Gamificação ───────────────────────────────────────────────────────────────

model UserXP {
  id     String @id @default(cuid())
  userId String @unique
  xp     Int    @default(0)
  level  Int    @default(1)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String?
  icon        String
  xpValue     Int         @default(0)

  userBadges  UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

// ─── Notificações ──────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum NotificationType {
  CONNECTION_REQUEST
  CONNECTION_ACCEPTED
  POST_COMMENT
  POST_LIKE
  NEW_MESSAGE
}
