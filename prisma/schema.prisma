generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth) ───────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Usuários ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  bio           String?
  role          Role      @default(STUDENT)
  password      String?

  // Stripe
  stripeCustomerId   String?            @unique
  subscriptionId     String?            @unique
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  subscriptionPlan   SubscriptionPlan?
  subscriptionEndsAt DateTime?

  instructorStatus   InstructorStatus @default(NONE)
  instructorBio      String?
  instructorLinkedin String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts     Account[]
  sessions     Session[]
  courses      Course[]      @relation("InstructorCourses")
  enrollments  Enrollment[]
  reviews      Review[]
  progress     Progress[]
  quizAttempts QuizAttempt[]
  certificates Certificate[]
  news         News[]        @relation("NewsAuthor")
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
}

enum SubscriptionPlan {
  MONTHLY
  ANNUAL
}

enum InstructorStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

// ─── Categorias ────────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  createdAt   DateTime @default(now())

  courses Course[]
}

// ─── Cursos ────────────────────────────────────────────────────────────────────

model Course {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String?
  thumbnail   String?
  price       Float   @default(0)
  isFree      Boolean @default(true)
  isPublished Boolean @default(false)
  level       Level   @default(BEGINNER)
  language    String  @default("pt-BR")
  duration    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instructorId String
  instructor   User      @relation("InstructorCourses", fields: [instructorId], references: [id])
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])

  modules      Module[]
  enrollments  Enrollment[]
  reviews      Review[]
  certificates Certificate[]
  tags         CourseTag[]
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

// ─── Tags ──────────────────────────────────────────────────────────────────────

model Tag {
  id      String      @id @default(cuid())
  name    String      @unique
  courses CourseTag[]
}

model CourseTag {
  courseId String
  tagId    String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([courseId, tagId])
}

// ─── Módulos e Aulas ───────────────────────────────────────────────────────────

model Module {
  id       String   @id @default(cuid())
  title    String
  order    Int
  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]

  createdAt DateTime @default(now())
}

model Lesson {
  id          String     @id @default(cuid())
  title       String
  description String?
  videoUrl    String?
  duration    Int?
  order       Int
  isFree      Boolean    @default(false)
  type        LessonType @default(VIDEO)
  content     String?
  moduleId    String
  module      Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress    Progress[]
  quiz        Quiz?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LessonType {
  VIDEO
  TEXT
  QUIZ
  NOTEBOOK
}

// ─── Quizzes ───────────────────────────────────────────────────────────────────

model Quiz {
  id                  String        @id @default(cuid())
  lessonId            String        @unique
  title               String
  description         String?
  passingScore        Int           @default(70)
  maxAttempts         Int?
  isCertificationExam Boolean       @default(false)
  lesson              Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions           Question[]
  attempts            QuizAttempt[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Question {
  id        String             @id @default(cuid())
  text      String
  order     Int                @default(1)
  quizId    String
  quiz      Quiz               @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options   Option[]
  responses QuestionResponse[]
}

model Option {
  id         String             @id @default(cuid())
  text       String
  order      Int                @default(1)
  isCorrect  Boolean            @default(false)
  questionId String
  question   Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  responses  QuestionResponse[]
}

model QuizAttempt {
  id            String             @id @default(cuid())
  quizId        String
  userId        String
  attemptNumber Int
  score         Int
  passed        Boolean            @default(false)
  submittedAt   DateTime           @default(now())
  quiz          Quiz               @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses     QuestionResponse[]

  @@unique([quizId, userId, attemptNumber])
}

model QuestionResponse {
  id         String      @id @default(cuid())
  attemptId  String
  questionId String
  optionId   String?
  attempt    QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question   Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option     Option?     @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@unique([attemptId, questionId])
}

// ─── Matrículas ────────────────────────────────────────────────────────────────

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId    String
  status      EnrollmentStatus @default(ACTIVE)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// ─── Progresso ─────────────────────────────────────────────────────────────────

model Progress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

// ─── Avaliações ────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

// ─── Certificados ──────────────────────────────────────────────────────────────

model Certificate {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  issuedAt   DateTime @default(now())
  code       String   @unique @default(cuid())
  finalScore Int?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

// ─── Banners ───────────────────────────────────────────────────────────────────

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  ctaText   String?
  ctaUrl    String   @default("/cursos")
  imageUrl  String?
  bgColor   String   @default("#edf5ff")
  textColor String   @default("#161616")
  isActive  Boolean  @default(true)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Notícias (News) ───────────────────────────────────────────────────────────

model News {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  summary   String?
  content   String   @db.Text
  imageUrl  String?
  category  String?
  published Boolean  @default(false)
  authorId  String
  author    User     @relation("NewsAuthor", fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
